# ══════════════════════════════════════
# ASUKA COUTURE — Environment Variables
# Copy this to .env.local and fill in
# Add these same vars in Netlify dashboard
# Site Settings → Environment Variables
# ══════════════════════════════════════

# GROQ API
# Already have this key
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# n8n AI Sizer webhook (already live)
N8N_SIZER_URL=https://n8n.diyaaaa.in/webhook/asuka-sizer

# Shopify (for product sync)
# Get from: Shopify Admin → Apps → Private apps
SHOPIFY_STORE_URL=https://asukacouture.myshopify.com
SHOPIFY_ADMIN_TOKEN=YOUR_SHOPIFY_ADMIN_TOKEN

# HuggingFace (for product embeddings, free)
# Get from: huggingface.co/settings/tokens
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN

# App URL (set after Netlify deploy)
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
